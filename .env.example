# WorkVault environment (copy to .env.local for local dev)

# API origin for desktop, mobile app, and self-hosted frontends.
# Leave empty for Netlify web (same-origin /api routes).
# VITE_API_BASE=https://workvault.netlify.app

# Self-hosted Docker: point at your API proxy or Netlify
# VITE_API_BASE=https://your-domain.com

# Desktop / Capacitor builds use Netlify by default when unset.
