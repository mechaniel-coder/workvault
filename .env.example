# WorkVault environment (copy to .env.local for local dev)

# --- Frontend (Vite) ---

# API origin for desktop, mobile, and self-hosted builds.
# Leave empty for Netlify web (same-origin /.netlify/functions routes).
# VITE_API_BASE=https://workvault.netlify.app

# --- Netlify Functions (netlify dev or Netlify dashboard) ---
# Full reference: docs/NETLIFY_ENV.md

# SITE_URL=https://workvault.netlify.app
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# RESEND_API_KEY=

# --- macOS signing (local build only, never commit) ---
# APPLE_SIGNING_IDENTITY=
# APPLE_ID=
# APPLE_PASSWORD=
# APPLE_TEAM_ID=
# See docs/MACOS_SIGNING.md
